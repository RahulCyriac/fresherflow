datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Job {
  id        String   @id @default(uuid())
  company   String
  status    String
  priority  String
  tags      String   @default("[]")
  notes     String?
  createdAt DateTime @default(now())
}
